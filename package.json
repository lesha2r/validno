{
  "name": "validno",
  "version": "0.4.7-beta.2",
  "description": "A lightweight TypeScript validation library for runtime data validation. Used as part of Kodzero API framework.",
  "keywords": [
    "validation",
    "schema",
    "typescript",
    "validator",
    "runtime-validation",
    "form-validation",
    "data-validation",
    "object-validation",
    "lightweight",
    "zod-alternative",
    "yup-alternative"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "tsc": "tsc -b src/",
    "tsc-watch": "tsc --b --watch src/",
    "tscw": "tsc --b --watch src/",
    "dev": "nodemon dist/dev.js",
    "docs": "npm run docs:dev",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:check": "tsc --target ES2020 --module NodeNext --moduleResolution NodeNext --esModuleInterop true --skipLibCheck true --outDir dist src/verify-docs.ts && node dist/verify-docs.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "prepublishOnly": "npm run tsc",
    "release:patch": "npm version patch  --message \"release: %s\" && npm publish",
    "release:minor": "npm version minor  --message \"release: %s\" && npm publish",
    "release:major": "npm version major  --message \"release: %s\" && npm publish",
    "release:beta": "npm version prerelease --preid=beta --message \"release: %s\" && npm publish --tag beta"
  },
  "files": [
    "dist/**/*",
    "!dist/verify-docs.*",
    "!dist/dev.*",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "author": "lesha2r",
  "license": "ISC",
  "dependencies": {
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^18.14.2",
    "eslint": "^8.14.0",
    "jest": "^29.7.0",
    "mongodb": "^6.19.0",
    "ts-jest": "^29.4.6",
    "vitepress": "^1.6.3"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lesha2r/validno.git"
  },
  "bugs": {
    "url": "https://github.com/lesha2r/validno/issues"
  },
  "homepage": "https://validno.kodzero.pro",
  "funding": {
    "type": "individual",
    "url": "https://kodzero.pro"
  }
}
